{
  "name": "immo-app",
  "version": "1.0.0",
  "description": "Wohnungssuche-App – scrapet Ebay Kleinanzeigen",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start":          "node src/server.js",
    "dev":            "node --watch src/server.js",
    "dev:client":     "cd client && npm run dev",
    "build:client":   "cd client && npm run build",
    "db":             "node scripts/query-db.js",
    "postinstall":    "playwright install chromium"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "node-cron": "^3.0.3",
    "playwright": "^1.42.1"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
