# Server
PORT=3000

# Scraper-Einstellungen
# Scheduler aktivieren (standardmäßig AUS). Auf 'true' setzen, um Cron zu aktivieren.
SCRAPE_CRON_ENABLED=false

# Scraping-Intervall (cron-Syntax), nur relevant wenn SCRAPE_CRON_ENABLED=true
# Beispiel: alle 30 Min → */30 * * * *
SCRAPE_CRON=*/30 * * * *

# Initial beim Serverstart einmal scrapen? (standardmäßig AUS)
SCRAPE_ON_START=false
